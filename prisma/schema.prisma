generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String        @id @default(cuid())
  name            String
  email           String        @unique
  role            String        @default("MERCHANT")
  merchantId      String?
  merchant        Merchant?     @relation(fields: [merchantId], references: [id])
  assignedAppeals Appeal[]      @relation("AppealAssignee")
  authoredAppeals Appeal[]      @relation("AppealAuthor")
  comments        AppealComment[]
  createdAt       DateTime      @default(now())

  @@index([merchantId], map: "User_merchantId_idx")
  @@index([role], map: "User_role_idx")
}

model Merchant {
  id              String              @id @default(cuid())
  name            String
  displayName     String
  status          String              @default("active")
  apiKey          String
  callbackUrl     String
  payinFeeRate    Decimal             @default(0.025)
  payoutFeeRate   Decimal             @default(0.015)
  trustLimit      Decimal             @default(0)
  createdAt       DateTime            @default(now())
  users           User[]
  orders          PaymentOrder[]
  payouts         Payout[]
  balances        BalanceAccount[]
  transactions    BalanceTransaction[]
  requisites      PaymentRequisite[]
  appeals         Appeal[]
  notifications   Notification[]

  @@index([displayName], map: "Merchant_displayName_idx")
  @@index([status], map: "Merchant_status_idx")
}

model Provider {
  id              String             @id @default(cuid())
  name            String
  displayName     String
  type            String
  status          String             @default("ACTIVE")
  commissionRate  Decimal            @default(0.018)
  availability    Int                @default(99)
  testMode        Boolean            @default(true)
  payinAvailable  Boolean            @default(true)
  payoutAvailable Boolean            @default(true)
  createdAt       DateTime           @default(now())
  orders          PaymentOrder[]
  requisites      PaymentRequisite[]

  @@index([displayName], map: "Provider_displayName_idx")
  @@index([status], map: "Provider_status_idx")
  @@index([availability], map: "Provider_availability_idx")
}

model PaymentRequisite {
  id              String           @id @default(cuid())
  merchantId      String?
  providerId      String?
  merchant        Merchant?        @relation(fields: [merchantId], references: [id])
  provider        Provider?        @relation(fields: [providerId], references: [id])
  type            String
  bank            String
  maskedNumber    String
  holder          String
  currency        String           @default("RUB")
  status          String           @default("ACTIVE")
  dailyLimit      Decimal          @default(0)
  dailyUsed       Decimal          @default(0)
  minAmount       Decimal          @default(0)
  maxAmount       Decimal          @default(0)
  linkedOrders    Int              @default(0)
  createdAt       DateTime         @default(now())
  orders          PaymentOrder[]

  @@index([merchantId, status], map: "PaymentRequisite_merchantId_status_idx")
  @@index([providerId], map: "PaymentRequisite_providerId_idx")
  @@index([status, createdAt], map: "PaymentRequisite_status_createdAt_idx")
}

model PaymentOrder {
  id              String           @id @default(cuid())
  externalId      String           @unique
  merchantId      String
  providerId      String?
  requisiteId     String?
  merchant        Merchant         @relation(fields: [merchantId], references: [id])
  provider        Provider?        @relation(fields: [providerId], references: [id])
  requisite       PaymentRequisite? @relation(fields: [requisiteId], references: [id])
  amount          Decimal
  currency        String           @default("RUB")
  status          String           @default("CREATED")
  orderType       String           @default("PAY-IN")
  providerName    String?
  commission      Decimal          @default(0)
  platformFee     Decimal          @default(0)
  merchantNet     Decimal          @default(0)
  paymentUrl      String?
  metadata        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  paidAt          DateTime?
  completedAt     DateTime?
  appeals         Appeal[]
  transactions    BalanceTransaction[]

  @@index([merchantId, createdAt], map: "PaymentOrder_merchantId_createdAt_idx")
  @@index([merchantId, status], map: "PaymentOrder_merchantId_status_idx")
  @@index([status, updatedAt], map: "PaymentOrder_status_updatedAt_idx")
  @@index([createdAt], map: "PaymentOrder_createdAt_idx")
}

model Payout {
  id              String         @id @default(cuid())
  merchantId      String
  merchant        Merchant       @relation(fields: [merchantId], references: [id])
  amount          Decimal
  currency        String         @default("RUB")
  status          String         @default("CREATED")
  recipient       String
  commission      Decimal        @default(0)
  sourceBalance   String         @default("Доступный баланс")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  completedAt     DateTime?
  transactions    BalanceTransaction[]

  @@index([merchantId, createdAt], map: "Payout_merchantId_createdAt_idx")
  @@index([merchantId, status], map: "Payout_merchantId_status_idx")
  @@index([status, updatedAt], map: "Payout_status_updatedAt_idx")
  @@index([createdAt], map: "Payout_createdAt_idx")
}

model BalanceAccount {
  id              String                @id @default(cuid())
  merchantId      String
  merchant        Merchant              @relation(fields: [merchantId], references: [id])
  type            String
  currency        String                @default("RUB")
  amount          Decimal               @default(0)
  updatedAt       DateTime              @updatedAt
  transactions    BalanceTransaction[]

  @@unique([merchantId, type, currency])
}

model BalanceTransaction {
  id              String            @id @default(cuid())
  merchantId      String
  merchant        Merchant          @relation(fields: [merchantId], references: [id])
  balanceId       String?
  balance         BalanceAccount?   @relation(fields: [balanceId], references: [id])
  orderId         String?
  order           PaymentOrder?     @relation(fields: [orderId], references: [id])
  payoutId        String?
  payout          Payout?           @relation(fields: [payoutId], references: [id])
  appealId        String?
  type            String
  direction       String
  amount          Decimal
  beforeAmount    Decimal
  afterAmount     Decimal
  currency        String            @default("RUB")
  description     String
  createdAt       DateTime          @default(now())

  @@index([merchantId, createdAt], map: "BalanceTransaction_merchantId_createdAt_idx")
  @@index([balanceId, createdAt], map: "BalanceTransaction_balanceId_createdAt_idx")
  @@index([orderId], map: "BalanceTransaction_orderId_idx")
  @@index([payoutId], map: "BalanceTransaction_payoutId_idx")
  @@index([appealId], map: "BalanceTransaction_appealId_idx")
}

model CommissionRule {
  id              String          @id @default(cuid())
  name            String
  type            String
  rate            Decimal
  minAmount       Decimal         @default(0)
  maxAmount       Decimal         @default(0)
  active          Boolean         @default(true)
  description     String

  @@index([type], map: "CommissionRule_type_idx")
  @@index([active], map: "CommissionRule_active_idx")
}

model ExchangeRate {
  id              String      @id @default(cuid())
  baseCurrency    String      @default("RUB")
  quoteCurrency   String
  rate            Decimal
  nominal         Int         @default(1)
  source          String      @default("CBR")
  sourceUrl       String?
  sourceDate      DateTime
  fetchedAt       DateTime    @default(now())
  staleAfter      DateTime?
  isManual        Boolean     @default(false)
  note            String?
  createdAt       DateTime    @default(now())

  @@unique([baseCurrency, quoteCurrency, sourceDate, source])
  @@index([baseCurrency, quoteCurrency, sourceDate])
}

model Appeal {
  id              String          @id @default(cuid())
  orderId         String
  merchantId      String
  authorId        String?
  assigneeId      String?
  order           PaymentOrder    @relation(fields: [orderId], references: [id])
  merchant        Merchant        @relation(fields: [merchantId], references: [id])
  author          User?           @relation("AppealAuthor", fields: [authorId], references: [id])
  assignee        User?           @relation("AppealAssignee", fields: [assigneeId], references: [id])
  reason          String
  status          String          @default("NEW")
  decision        String?
  frozenAmount    Decimal         @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  resolvedAt      DateTime?
  comments        AppealComment[]

  @@index([merchantId, status], map: "Appeal_merchantId_status_idx")
  @@index([status, updatedAt], map: "Appeal_status_updatedAt_idx")
  @@index([orderId], map: "Appeal_orderId_idx")
  @@index([createdAt], map: "Appeal_createdAt_idx")
}

model AppealComment {
  id              String       @id @default(cuid())
  appealId        String
  userId          String?
  appeal          Appeal       @relation(fields: [appealId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])
  authorRole      String
  message         String
  createdAt       DateTime     @default(now())

  @@index([appealId, createdAt], map: "AppealComment_appealId_createdAt_idx")
}

model Notification {
  id              String             @id @default(cuid())
  role            String
  merchantId      String?
  merchant        Merchant?          @relation(fields: [merchantId], references: [id])
  title           String
  message         String
  type            String             @default("INFO")
  read            Boolean            @default(false)
  createdAt       DateTime           @default(now())

  @@index([role, createdAt], map: "Notification_role_createdAt_idx")
  @@index([merchantId, createdAt], map: "Notification_merchantId_createdAt_idx")
  @@index([read, createdAt], map: "Notification_read_createdAt_idx")
  @@index([createdAt], map: "Notification_createdAt_idx")
}

model EventLog {
  id              String       @id @default(cuid())
  actorRole       String
  actorName       String
  entityType      String
  entityId        String
  type            String
  title           String
  description     String
  metadata        String?
  createdAt       DateTime     @default(now())

  @@index([createdAt], map: "EventLog_createdAt_idx")
  @@index([type, createdAt], map: "EventLog_type_createdAt_idx")
  @@index([entityType, entityId], map: "EventLog_entityType_entityId_idx")
  @@index([actorRole, createdAt], map: "EventLog_actorRole_createdAt_idx")
}

model ScenarioState {
  id              String       @id @default(cuid())
  key             String       @unique
  title           String
  description     String
  step            Int          @default(0)
  totalSteps      Int
  updatedAt       DateTime     @updatedAt
}
